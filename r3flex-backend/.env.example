# Database
# asyncpg driver required
DATABASE_URL=postgresql+asyncpg://r3flex:r3flex_secret@localhost:5432/r3flex
POSTGRES_USER=r3flex
POSTGRES_PASSWORD=r3flex_secret
POSTGRES_DB=r3flex

# Redis
REDIS_URL=redis://localhost:6379

# LLM
# Get key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash
LLM_MAX_TOKENS=1000

# Live signal feeds
# NewsAPI: https://newsapi.org/register
NEWS_API_KEY=

# NOAA Climate Data: https://www.ncdc.noaa.gov/cdo-web/token
NOAA_API_KEY=

# Optional JSON feed returning live normalized port signals
PORT_SIGNALS_URL=

# Local/demo fallback used when no external live providers return signals
DEMO_SIGNAL_FALLBACK_ENABLED=true

# Runtime supply network data
# JSON file with `nodes`, `edges`, and optional `shipments`
SUPPLIER_GRAPH_PATH=

# Optional separate shipments JSON file
SHIPMENTS_DATA_PATH=

# Business rules
CONFIDENCE_THRESHOLD=0.85
COMPANY_ID=default
POLL_INTERVAL_SECONDS=60

# App
APP_ENV=development
LOG_LEVEL=INFO
